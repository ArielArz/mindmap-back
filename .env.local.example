PORT=Puerto en el que se va a ejecutar tu app
DB_HOST=Nombre de host de tu base de datos
DB_PORT=Puerto de tu base de datos
DB_USER=Usuario de tu base de datos
DB_PASS=Contraseña de tu base de datos
DB_NAME=Nombre de tu base de datos
CLOUDINARY_CLOUD_NAME=Nombre del cloud de tu cuenta de Cloudinary
CLOUDINARY_API_KEY=Clave API (API Key) de tu cuenta de Cloudinary
CLOUDINARY_API_SECRET=Secreto API (API Secret) de tu cuenta de Cloudinary
JWT_SECRET=Clave secreta usada para firmar y verificar los JWT

MAIL_FROM_NAME=Nombre que aparecerá como remitente en los correos enviados
MAIL_FROM_EMAIL=Correo electrónico que aparecerá como remitente en los correos enviados
SENDGRID_API_KEY=ApiKey de servicio de sendgrid